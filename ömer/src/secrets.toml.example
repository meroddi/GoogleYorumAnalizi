# Bu dosyayı Streamlit Cloud → Settings → Secrets kısmına yapıştırın.
# Bilgisayarınızda .streamlit/secrets.toml olarak saklayabilirsiniz ama
# Bu projede uygulama hem .streamlit/secrets.toml hem src/.streamlit/secrets.toml yolunu okur.
# ASLA GitHub'a göndermeyin (.gitignore'da zaten var).

OAUTH_CLIENT_ID     = "google-web-client-id"
OAUTH_CLIENT_SECRET = "google-web-client-secret"
OAUTH_REFRESH_TOKEN = "google-refresh-token"

PLACES_API_KEY      = "google-places-api-key"

# Şifrenin SHA-256 hash'ini üretmek için terminalde şunu çalıştırın:
# python3 -c "import hashlib; print(hashlib.sha256('ŞİFRENİZ'.encode()).hexdigest())"
APP_PASSWORD_HASH   = "buraya-sifrenizin-sha256-hashini-yapistirin"
